<h6>Dashboard</h6>
<h3>Welcome {{name}}</h3>
<p>Here are you stories</p>
{{#if stories}}
    <table>
        <thead>
            <tr>
                <th>Title</th>
                <th>Date</th>
                <th>Status</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            {{#each stories}}
                <tr>
                    <td><a href="/stories/{{_id}}">{{title}}</a></td>
                    <td>{{createdAt}}</td>
                    <td>{{status}}</td>
                    <td>
                        <a href="/stories/edit/{{_id}}">Edit</a>
                        <a href="/stories/delete/{{_id}}">Delete</a>
                    </td>
                </tr>
            {{/each}}
        </tbody>
    </table>
{{else}}
    <p>You have not created any stories</p>
{{/if}}